# =============================================================================
# ClearCost — Environment Variables
# Copy to .env and fill in real values. All vars listed in turbo.json.
# =============================================================================

# -----------------------------------------------------------------------------
# Node / Runtime
# -----------------------------------------------------------------------------
NODE_ENV=development
DEBUG=

# -----------------------------------------------------------------------------
# Database (PostgreSQL 17 — see docker-compose.yml)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://clearcost:clearcost@localhost:5432/clearcost

# -----------------------------------------------------------------------------
# API Server
# -----------------------------------------------------------------------------
HOST=0.0.0.0                        # Public server bind address
PORT=3001                           # Public server port
INTERNAL_HOST=127.0.0.1             # Internal server bind address
INTERNAL_PORT=3002                  # Internal server port
ALLOW_INTERNAL_BIND=                # Set to "1" to allow 0.0.0.0 internal bind in production
TRUST_PROXY=                        # "true", "false", or hop count (e.g. "1")
RATE_LIMIT_MAX=600                  # Max requests per window per API key / IP
RATE_LIMIT_WINDOW=1 minute          # Rate limit time window
HTTP_TIMEOUT_MS=30000               # Global HTTP client timeout
HTTP_USER_AGENT=ClearCost/1.0       # User-Agent for outbound HTTP requests

# -----------------------------------------------------------------------------
# Auth (Better Auth)
# -----------------------------------------------------------------------------
BETTER_AUTH_URL=http://localhost:3000  # Better Auth issuer URL
BETTER_AUTH_SECRET=                    # Auth signing secret (generate a random 32+ char string)
BETTER_AUTH_COOKIE_DOMAIN=localhost    # Cookie domain for auth sessions

# -----------------------------------------------------------------------------
# API Key Security
# -----------------------------------------------------------------------------
API_KEY_PEPPER=                      # HMAC pepper for API key hashing (required in production)
ADMIN_TOKEN=                         # Static admin bearer token
INTERNAL_SIGNING_SECRET=             # HMAC secret for internal server request signing (required in production)
CLEARCOST_ADMIN_API_KEY=             # Admin-scoped API key for internal tooling
CLEARCOST_API_KEY=                   # Default API key for SDK / integration tests
CLEARCOST_DEMO_API_KEY=              # API key used by docs playground demo
CLEARCOST_TASKS_API_KEY=             # API key for scheduled task / cron runners
CLEARCOST_WEB_SERVER_KEY=            # Server-side API key used by the web app
EMAIL_OTP_API_SECRET=                # Secret for email OTP verification

# -----------------------------------------------------------------------------
# App URLs
# -----------------------------------------------------------------------------
API_URL=http://localhost:3001                 # Canonical API URL
CLEARCOST_API_BASE_URL=http://localhost:3001  # SDK / client base URL
CLEARCOST_API_URL=http://localhost:3001       # Alias used by some packages
CLEARCOST_BASE_URL=http://localhost:3000      # Web app base URL
WEB_ORIGIN=http://localhost:3000              # Allowed CORS origin for the web app
NEXT_PUBLIC_API_BASE=http://localhost:3001    # Client-side API base (Next.js public)
NEXT_PUBLIC_BASE_URL=http://localhost:3000    # Client-side web base (Next.js public)
NEXT_PUBLIC_CLEARCOST_API_URL=http://localhost:3001  # Client-side API URL (Next.js public)

# -----------------------------------------------------------------------------
# Next.js
# -----------------------------------------------------------------------------
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=  # Encryption key for server actions
NEXT_PHASE=                          # Next.js build phase (set automatically)

# -----------------------------------------------------------------------------
# Stripe / Billing
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...        # Stripe secret key
STRIPE_WEBHOOK_SECRET=whsec_...      # Stripe webhook endpoint signing secret
STRIPE_PRICE_STARTER=price_...       # Stripe Price ID for Starter plan
STRIPE_PRICE_GROWTH=price_...        # Stripe Price ID for Growth plan
STRIPE_PRICE_SCALE=price_...         # Stripe Price ID for Scale plan

# -----------------------------------------------------------------------------
# Plan Limits
# -----------------------------------------------------------------------------
CC_LIMIT_FREE_MAX_MANIFESTS=5              # Max manifests for Free plan
CC_LIMIT_FREE_MAX_ITEMS_PER_MANIFEST=10    # Max items per manifest for Free plan
CC_LIMIT_STARTER_MAX_MANIFESTS=50          # Max manifests for Starter plan
CC_LIMIT_STARTER_MAX_ITEMS_PER_MANIFEST=100  # Max items per manifest for Starter plan
CC_LIMIT_GROWTH_MAX_MANIFESTS=500          # Max manifests for Growth plan
CC_LIMIT_GROWTH_MAX_ITEMS_PER_MANIFEST=500   # Max items per manifest for Growth plan
CC_LIMIT_SCALE_MAX_MANIFESTS=10000         # Max manifests for Scale plan
CC_LIMIT_SCALE_MAX_ITEMS_PER_MANIFEST=5000   # Max items per manifest for Scale plan

# -----------------------------------------------------------------------------
# Redis / Upstash KV
# -----------------------------------------------------------------------------
REDIS_URL=                           # Redis connection URL
REDIS_TOKEN=                         # Redis auth token
KV_REST_API_URL=                     # Upstash KV REST endpoint
KV_REST_API_TOKEN=                   # Upstash KV REST auth token
UPSTASH_REDIS_REST_URL=              # Upstash Redis REST endpoint
UPSTASH_REDIS_REST_TOKEN=            # Upstash Redis REST auth token
UPSTASH_CONSOLE=                     # Upstash console URL
UPSTASH_DISABLE_TELEMETRY=1          # Disable Upstash SDK telemetry

# -----------------------------------------------------------------------------
# LLM / AI (HS classification)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...                # OpenAI API key for classification
OPENAI_MODEL=gpt-4o                  # OpenAI model name
GROK_API_KEY=                        # xAI Grok API key (alternative LLM)
GROK_MODEL=                          # Grok model name
XAI_API_KEY=                         # xAI API key
LLM_DUTY_SOURCE=                     # LLM provider for duty lookups

# -----------------------------------------------------------------------------
# Foreign Exchange
# -----------------------------------------------------------------------------
OXR_APP_ID=                          # Open Exchange Rates app ID
CURRENCY_BASE=USD                    # Base currency for FX rates
FX_MAX_AGE_HOURS=24                  # Max age before FX rates are considered stale
FX_SECONDARY=                        # Secondary FX provider
FX_SECONDARY_MAX_LAG_DAYS=           # Max lag for secondary FX source

# -----------------------------------------------------------------------------
# External Trade APIs
# -----------------------------------------------------------------------------
TRADE_GOV_API_KEY=                   # Trade.gov API key
HTS_API_BASE=                        # HTS API base URL
HTS_CSV_URL=                         # HTS tariff CSV download URL
HTS_JSON_URL=                        # HTS tariff JSON download URL
HS_ALIAS_TITLE_MAX=                  # Max title length for HS aliases

# -----------------------------------------------------------------------------
# Data Import / Cron
# -----------------------------------------------------------------------------
DATA_REMOTE_BASE=                    # Remote base URL for data file downloads
DB_DATA_API_BASE=                    # Data API base URL
BATCH_SIZE=1000                      # Import batch size
IMPORT_STALE_MINUTES=60              # Minutes before an import is considered stale
IMPORTS_SWEEP_THRESHOLD_MINUTES=120  # Minutes before stale imports are swept
IMPORT_AGE_BUCKETS=                  # Histogram bucket boundaries for import age metrics

# -----------------------------------------------------------------------------
# US Tariff Config
# -----------------------------------------------------------------------------
US_MPF_PCT=0.3464                    # US Merchandise Processing Fee percentage
US_MPF_MIN=31.67                     # US MPF minimum
US_MPF_MAX=614.35                    # US MPF maximum
US_MPF_EFFECTIVE=                    # US MPF effective date
US_MPF_NOTES=                        # US MPF notes
US_HMF_PCT=0.125                     # US Harbor Maintenance Fee percentage
US_HMF_EFFECTIVE=                    # US HMF effective date
US_HMF_NOTES=                        # US HMF notes

# -----------------------------------------------------------------------------
# EU TARIC (European Union tariff data)
# -----------------------------------------------------------------------------
EU_TARIC_ATTRIBUTION=                # TARIC data attribution string
EU_TARIC_DAILY_LIST=                 # TARIC daily update list URL
EU_TARIC_COMPONENT_URL=              # TARIC component download URL
EU_TARIC_DUTY_EXPR_URL=              # TARIC duty expression URL
EU_TARIC_GEO_DESC_URL=              # TARIC geographical area descriptions URL
EU_TARIC_GOODS_DESC_URL=            # TARIC goods descriptions URL
EU_TARIC_GOODS_URL=                  # TARIC goods nomenclature URL
EU_TARIC_MEASURE_URL=                # TARIC measure download URL
EU_TARIC_REMEDY_TYPES=               # Comma-separated TARIC remedy measure type IDs
EU_TARIC_LANGUAGE=EN                 # TARIC data language code

# -----------------------------------------------------------------------------
# UK Tariff
# -----------------------------------------------------------------------------
UK_10_DATA_API_BASE=                 # UK Trade Tariff API base URL
UK_REMEDY_MEASURE_TYPES=             # Comma-separated UK remedy measure type IDs
UK_TARIFF_VERSION_ID=                # UK tariff version identifier

# -----------------------------------------------------------------------------
# Japan Tariff
# -----------------------------------------------------------------------------
JP_ETAX_ATTRIBUTION=                 # Japan e-Tax attribution string
JP_ETAX_BASE=                        # Japan e-Tax base URL
JP_TARIFF_INDEX=                     # Japan tariff index URL

# -----------------------------------------------------------------------------
# China Tariff
# -----------------------------------------------------------------------------
CN_GACC_NOTICE_URLS=                 # China GACC notice URLs (comma-separated)
CN_MOFCOM_NOTICE_URLS=               # China MOFCOM notice URLs (comma-separated)
CN_MOF_NOTICE_URLS=                  # China MOF notice URLs (comma-separated)
CN_TARIFF_ATTRIBUTION=               # China tariff data attribution
CN_TARIFF_BASE=                      # China tariff base URL
CN_TAXBOOK_2025_URL=                 # China 2025 tax book download URL
CN_TAXBOOK_ATTRIBUTION=              # China tax book attribution

# -----------------------------------------------------------------------------
# AHTN (ASEAN Harmonized Tariff Nomenclature)
# -----------------------------------------------------------------------------
AHTN_CSV_URL=                        # AHTN CSV download URL
AHTN_SOURCE_URL=                     # AHTN source page URL

# -----------------------------------------------------------------------------
# Indonesia Tariff (BTKI)
# -----------------------------------------------------------------------------
ID_BTKI_CRAWL_START=                 # BTKI crawl start page
ID_BTKI_COL_FROM=                    # BTKI spreadsheet column: effective from
ID_BTKI_COL_HS=                      # BTKI spreadsheet column: HS code
ID_BTKI_COL_MFN=                     # BTKI spreadsheet column: MFN rate
ID_BTKI_COL_TO=                      # BTKI spreadsheet column: effective to
ID_BTKI_EFFECTIVE_FROM=              # BTKI effective-from date override
ID_BTKI_OUT_DIR=                     # BTKI output directory
ID_BTKI_SHEET=                       # BTKI Excel sheet name
ID_BTKI_START_URL=                   # BTKI start URL for crawling
ID_BTKI_XLSX_URL=                    # BTKI XLSX download URL

# -----------------------------------------------------------------------------
# Malaysia Tariff
# -----------------------------------------------------------------------------
MY_MFN_EXCEL_URL=                    # Malaysia MFN tariff Excel URL
MY_MFN_SHEET=                        # Malaysia MFN Excel sheet name
MY_PREFERENTIAL_EXCEL_URL=           # Malaysia preferential tariff Excel URL
MY_PREFERENTIAL_SHEET=               # Malaysia preferential Excel sheet name
MY_TARIFF_ATTRIBUTION=               # Malaysia tariff data attribution

# -----------------------------------------------------------------------------
# Philippines Tariff
# -----------------------------------------------------------------------------
PH_TARIFF_ATTRIBUTION=               # Philippines tariff data attribution
PH_TARIFF_EXCEL_URL=                 # Philippines tariff Excel URL
PH_TARIFF_SHEET=                     # Philippines tariff Excel sheet name

# -----------------------------------------------------------------------------
# Vietnam Tariff
# -----------------------------------------------------------------------------
VN_TARIFF_ATTRIBUTION=               # Vietnam tariff data attribution
VN_TARIFF_BASE=                      # Vietnam tariff base URL

# -----------------------------------------------------------------------------
# Notices Crawler
# -----------------------------------------------------------------------------
NOTICES_CONCURRENCY=5                # Max concurrent notice fetches
NOTICES_EXCLUDE_HINTS=               # Comma-separated URL hints to exclude
NOTICES_INCLUDE_HINTS=               # Comma-separated URL hints to include
NOTICES_MAX_DEPTH=3                  # Max crawl depth for notices
NOTICES_OUT_DIR=                     # Output directory for crawled notices
NOTICES_USER_AGENT=                  # User-Agent for notice crawler

# -----------------------------------------------------------------------------
# VAT
# -----------------------------------------------------------------------------
VAT_DEBUG=                           # Enable VAT debug logging
VAT_MIN_ROWS=                        # Minimum VAT rows required for import validation

# -----------------------------------------------------------------------------
# Quotes
# -----------------------------------------------------------------------------
QUOTE_STRICT_FRESHNESS=              # Enforce strict data freshness checks for quotes

# -----------------------------------------------------------------------------
# Webhooks
# -----------------------------------------------------------------------------
WEBHOOK_KMS_KEY=                     # KMS key ARN for webhook payload signing
CLEARCOST_WEBHOOK_TIMEOUT_MS=5000    # Webhook delivery timeout in ms
CONTACT_WEBHOOK_URL=                 # Webhook URL for contact form submissions

# -----------------------------------------------------------------------------
# Notifications (Slack / Discord)
# -----------------------------------------------------------------------------
SLACK_BOT_TOKEN=xoxb-...             # Slack bot OAuth token
SLACK_CHANNEL_ID=C...                # Slack channel ID for notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...  # Slack incoming webhook URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...  # Discord webhook URL

# -----------------------------------------------------------------------------
# AWS
# -----------------------------------------------------------------------------
AWS_REGION=us-east-1                 # AWS region for KMS, etc.

# -----------------------------------------------------------------------------
# Cloudflare Turnstile
# -----------------------------------------------------------------------------
TURNSTILE_SECRET_KEY=                # Cloudflare Turnstile secret key for bot protection

# -----------------------------------------------------------------------------
# Metrics / Observability
# -----------------------------------------------------------------------------
METRICS_REQUIRE_SIGNING=             # "1" to require HMAC signing on /metrics endpoint

# -----------------------------------------------------------------------------
# Proxy Toggles (docs / widget)
# -----------------------------------------------------------------------------
ENABLE_DOCS_PLAYGROUND_PROXY=        # "1" to enable API proxy in docs playground
ENABLE_PUBLIC_WIDGET_PROXY=          # "1" to enable public widget API proxy

# -----------------------------------------------------------------------------
# WITS (World Integrated Trade Solution)
# -----------------------------------------------------------------------------
WITS_ALLOW_ALL=                      # "1" to allow all WITS data sources
WITS_LOG=                            # Enable WITS debug logging

# -----------------------------------------------------------------------------
# CI / Build (usually set by CI, not locally)
# -----------------------------------------------------------------------------
BUILD_TIME=                          # Build timestamp (set by CI)
COMMIT_SHA=                          # Git commit SHA (set by CI)
GIT_SHA=                             # Git SHA alias
CODECOV_TOKEN=                       # Codecov upload token

# -----------------------------------------------------------------------------
# Vercel (set automatically on Vercel, not needed locally)
# -----------------------------------------------------------------------------
# VERCEL=
# VERCEL_ENV=
# VERCEL_URL=
# VERCEL_BRANCH_URL=
# VERCEL_PROJECT_PRODUCTION_URL=
# VERCEL_GIT_COMMIT_SHA=

# -----------------------------------------------------------------------------
# System (usually set by OS, not manually)
# -----------------------------------------------------------------------------
# APPDATA=
